#!/usr/bin/env sh

set -eu

if command -v pwsh >/dev/null 2>&1; then
  PS_BIN="pwsh"
elif command -v powershell >/dev/null 2>&1; then
  PS_BIN="powershell"
else
  echo "[pre-commit] PowerShell(pwsh/powershell)을 찾을 수 없습니다."
  exit 1
fi

"$PS_BIN" -NoProfile -ExecutionPolicy Bypass -File "./scripts/pre-commit-secrets.ps1"

